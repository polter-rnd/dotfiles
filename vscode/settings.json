{
    /* Telemetry */
    "telemetry.telemetryLevel": "off",
    "redhat.telemetry.enabled": false,
    "window.titleBarStyle": "custom",
    "window.commandCenter": true,
    "window.autoDetectColorScheme": true,
    "workbench.preferredDarkColorTheme": "Adwaita Dark",
    "workbench.preferredLightColorTheme": "Adwaita Light",
    "workbench.colorTheme": "Adwaita Dark & default syntax highlighting",
    "workbench.productIconTheme": "adwaita",
    "workbench.tree.indent": 12,
    "workbench.editor.showTabs": false,

    /* Workaround for losing focus on Alt key */
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,

    /* Explorer */
    "explorer.confirmDelete": false,
    "explorer.openEditors.visible": 40,
    "explorer.openEditors.sortOrder": "alphabetical",
    /*"explorer.excludeGitIgnore": true,*/
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },

    /* Editor */
    "editor.rulers": [
        100
    ],
    "editor.renderWhitespace": "all",
    "editor.suggestSelection": "first",
    "editor.minimap.enabled": true,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",

    /* Java */
    "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx8G -Xms100m",
    "java.jdt.ls.java.home": "/usr/lib/jvm/java-17-openjdk",
    "spring-boot.ls.java.home": "/usr/lib/jvm/java-11-openjdk/",
    "maven.executable.path": "/home/polter/.local/opt/maven/bin/mvn",
    "java.project.importOnFirstTimeStartup": "automatic",
    "java.import.generatesMetadataFilesAtProjectRoot": true,
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-11",
            "path": "/usr/lib/jvm/java-11-openjdk",
            "default":  true
        },
        {
            "name": "JavaSE-17",
            "path": "/usr/lib/jvm/java-17-openjdk"
        }
    ],

    /* Git */
    "git.mergeEditor": true,
    "git.showActionButton": {
        "commit": true,
        "publish": true,
        "sync": true
    },
    "git.terminalGitEditor": true,
    "git.useEditorAsCommitInput": true,

    /* Terminal */
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.sendKeybindingsToShell": true,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.gpuAcceleration": "off",

    /* Container settings */
    "docker.dockerPath": "/usr/bin/podman",
    "docker.composeCommand": "/usr/bin/podman-compose",
    "docker.host": "unix:///run/user/1000/podman/podman.sock",
    "dev.containers.dockerComposePath": "/usr/bin/podman-compose",
    "dev.containers.dockerPath": "/usr/bin/podman",
    "window.zoomLevel": 1,
    "sqltools.useNodeRuntime": true
}
